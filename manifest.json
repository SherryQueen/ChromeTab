{
    "manifest_version": 2,
    "name": "56のTab",
    "version": "1.0",
    "description": "One chrome extension for myself",
    "icons": {
        "16": "img/icon16.png",
        "48": "img/icon48.png",
        "128": "img/icon128.png"
    },
    "browser_action": {
        "default_icon": {
            "19": "img/icon19.png",
            "38": "img/icon38.png"
        }
    },
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "permissions": [
        "<all_urls>",
        "storage",
        "topSites"
    ],
    "web_accessible_resources": [
        "images/*.png"
    ]
}
